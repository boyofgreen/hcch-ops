{
  "name": "hccc-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hill Country Cider House operations site",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w server\" \"npm run dev -w web\"",
    "build": "npm run build -w web && npm run build -w server",
    "start": "npm run start -w server",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0"
  }
}
